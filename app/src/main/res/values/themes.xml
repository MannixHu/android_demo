<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroidDemo" parent="android:Theme.Material3.Dark">
        <!-- Material 3 colors are handled in Compose via Theme.kt -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <!-- Light theme variant if needed -->
    <style name="Theme.AndroidDemo.Light" parent="android:Theme.Material3.Light">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>
</resources>
